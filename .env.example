# Database
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (최소 32자 이상)
JWT_SECRET=your-secret-key-here-minimum-32-characters

# 이메일 발송 (Gmail SMTP — 구글 계정 앱 비밀번호 발급 필요)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# 카카오 소셜 로그인 (https://developers.kakao.com)
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao/callback

# AWS S3 파일 업로드
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
S3_BUCKET_NAME=your-s3-bucket-name

# 결제 - 토스페이먼츠 (https://developers.tosspayments.com)
TOSS_SECRET_KEY=your-toss-secret-key

# 결제 - 카카오페이
KAKAO_PAY_CID=TC0ONETIME

# 결제 - 네이버페이
NAVER_PAY_CLIENT_ID=your-naverpay-client-id
NAVER_PAY_CLIENT_SECRET=your-naverpay-client-secret

# 배송 추적 - tracker.delivery (https://console.tracker.delivery)
TRACKER_CLIENT_ID=your-tracker-client-id
TRACKER_CLIENT_SECRET=your-tracker-client-secret

# CORS 허용 origin (prod profile에서 override). 콤마로 구분.
# 미설정 시 application-prod.yml의 default(www.myfave.shop, myfave.shop) 사용
APP_CORS_ALLOWED_ORIGINS=https://www.myfave.shop,https://myfave.shop
