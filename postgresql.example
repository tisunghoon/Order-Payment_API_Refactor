-- ==========================================
-- 1. ENUM 타입 생성 (테이블 생성 전 필수)
-- ==========================================
CREATE TYPE delivery_status_enum AS ENUM ('PREPARING', 'SHIPPING', 'DELIVERED', 'CANCELLED');
CREATE TYPE order_type_enum AS ENUM ('CART', 'DIRECT');
CREATE TYPE order_status_enum AS ENUM ('PENDING', 'PAID', 'CANCELLED', 'REFUNDED');
CREATE TYPE payment_method_enum AS ENUM ('CREDITCARD', 'TOSS', 'KAKAO_PAY', 'NAVER_PAY');
CREATE TYPE payment_status_enum AS ENUM ('PENDING', 'COMPLETE', 'FAILED', 'CANCELLED');
CREATE TYPE coupon_status_enum AS ENUM ('AVAILABLE', 'USED', 'EXPIRED');
CREATE TYPE coupon_type_enum AS ENUM ('DISCOUNT', 'SHIPPING');
CREATE TYPE short_form_type_enum AS ENUM ('BANNER', 'PRODUCT_LIST');
CREATE TYPE condition_code_enum AS ENUM ('S_GRADE', 'A_GRADE', 'B_GRADE', 'C_GRADE');
CREATE TYPE category_code_enum AS ENUM ('ALL', 'TOP', 'BOTTOM', 'OUTER', 'ACCESSORY');


-- ==========================================
-- 2. 테이블 생성 (모든 명칭 소문자 스네이크 케이스 적용)
-- ==========================================

CREATE TABLE "users" (
	"user_id"		BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"email"			VARCHAR(100)	NOT NULL,
	"password"		VARCHAR(255)	NOT NULL,
	"name"			VARCHAR(20)		NOT NULL,
	"nickname"		VARCHAR(12)		NOT NULL,
	"phone"			VARCHAR(20)		NOT NULL,
	"created_at"	TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"	TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "sale_events" (
	"sale_id"		BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"event_name"	VARCHAR(100)	NOT NULL,
	"sale_start_at"	TIMESTAMPTZ		NOT NULL,
	"sale_end_at"	TIMESTAMPTZ		NOT NULL,
	"created_at"	TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"	TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "products" (
	"product_id"		BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"user_id"			BIGINT					NOT NULL,
	"product_name"		VARCHAR(100)			NOT NULL,
	"short_review"		VARCHAR(255)			NULL,
	"price"				INT						NOT NULL,
	"description"		TEXT					NULL,
	"size"				VARCHAR(100)			NULL,
	"condition_code"	condition_code_enum		NOT NULL,
	"category_code"		category_code_enum		NULL,
	"is_soldout"		BOOLEAN					NOT NULL	DEFAULT FALSE,
	"created_at"		TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "orders" (
	"orders_id"			BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"user_id"			BIGINT				NOT NULL,
	"order_number"		VARCHAR(30)			NOT NULL,
	"order_type"		order_type_enum		NOT NULL,
	"order_status"		order_status_enum	NOT NULL	DEFAULT 'PENDING',
	"final_payment_id"	BIGINT				NULL,
	"created_at"		TIMESTAMPTZ			NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ			NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "deliveries" (
	"delivery_id"		BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"orders_id"			BIGINT					NOT NULL,
	"receiver_name"		VARCHAR(255)			NOT NULL,
	"receiver_phone"	VARCHAR(20)				NOT NULL,
	"receiver_address"	VARCHAR(255)			NOT NULL,
	"delivery_request"	VARCHAR(50)				NULL,
	"courier_name"		VARCHAR(50)				NULL,
	"tracking_number"	VARCHAR(50)				NULL,
	"delivery_status"	delivery_status_enum	NOT NULL	DEFAULT 'PREPARING',
	"shipped_at"		TIMESTAMPTZ				NULL,
	"delivered_at"		TIMESTAMPTZ				NULL,
	"created_at"		TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "cart_items" (
	"cart_id"		BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"user_id"		BIGINT		NOT NULL,
	"product_id"	BIGINT		NOT NULL,
	"created_at"	TIMESTAMPTZ	NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "shipping_addresses" (
	"shipping_id"		BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"user_id"			BIGINT			NOT NULL,
	"receiver_name"		VARCHAR(20)		NOT NULL,
	"receiver_phone"	VARCHAR(20)		NOT NULL,
	"address"			VARCHAR(255)	NOT NULL,
	"address_detail"	VARCHAR(100)	NULL,
	"zip_code"			VARCHAR(10)		NOT NULL,
	"delivery_request"	VARCHAR(100)	NULL,
	"is_default"		BOOLEAN			NOT NULL	DEFAULT FALSE,
	"created_at"		TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "coupon_masters" (
	"coupon_master_id"	BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"coupon_name"		VARCHAR(100)		NOT NULL,
	"coupon_type"		coupon_type_enum	NOT NULL,
	"discount_price"	INT					NOT NULL,
	"is_active"			BOOLEAN				NOT NULL	DEFAULT TRUE,
	"created_at"		TIMESTAMPTZ			NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ			NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "coupons" (
	"coupon_id"			BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"coupon_master_id"	BIGINT				NOT NULL,
	"user_id"			BIGINT				NOT NULL,
	"status"			coupon_status_enum	NOT NULL	DEFAULT 'AVAILABLE',
	"expired_at"		TIMESTAMPTZ			NOT NULL,
	"created_at"		TIMESTAMPTZ			NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ			NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "order_items" (
	"order_items_id"	BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"product_id"		BIGINT			NOT NULL,
	"orders_id"			BIGINT			NOT NULL,
	"price"				INT				NOT NULL,
	"product_name"		VARCHAR(100)	NOT NULL,
	"created_at"		TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "product_images" (
	"product_img_id"	BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"product_id"		BIGINT			NOT NULL,
	"image_url"			VARCHAR(255)	NOT NULL,
	"sort_order"		INT				NOT NULL,
	"is_main"			BOOLEAN			NOT NULL	DEFAULT FALSE,
	"created_at"		TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"		TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "payments" (
	"payment_id"			BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"orders_id"				BIGINT					NOT NULL,
	"coupon_id"				BIGINT					NULL,
	"payment_method"		payment_method_enum		NULL,
	"total_product_price"	INT						NOT NULL	DEFAULT 0,
	"delivery_fee"			INT						NOT NULL	DEFAULT 0,
	"discount_price"		INT						NOT NULL	DEFAULT 0,
	"total_payment_price"	INT						NOT NULL	DEFAULT 0,
	"payment_status"		payment_status_enum		NOT NULL	DEFAULT 'PENDING',
	"created_at"			TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"updated_at"			TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "chat_rooms" (
	"chat_room_id"	BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"user_id"		BIGINT		NOT NULL,
	"sale_id"		BIGINT		NOT NULL,
	"is_active"		BOOLEAN		NOT NULL	DEFAULT TRUE,
	"created_at"	TIMESTAMPTZ	NOT NULL	DEFAULT CURRENT_TIMESTAMP,
	"closed_at"		TIMESTAMPTZ	NULL
);

CREATE TABLE "short_forms" (
	"short_form_id"	BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"product_id"	BIGINT					NULL,
	"display_type"	short_form_type_enum	NOT NULL,
	"video_url"		VARCHAR(500)			NOT NULL,
	"thumbnail_url"	VARCHAR(500)			NOT NULL,
	"created_at"	TIMESTAMPTZ				NOT NULL	DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE "style_feeds" (
	"style_feeds_id"	BIGINT GENERATED BY DEFAULT AS IDENTITY	NOT NULL,
	"product_id"		BIGINT			NOT NULL,
	"image_url"			VARCHAR(500)	NOT NULL,
	"created_at"		TIMESTAMPTZ		NOT NULL	DEFAULT CURRENT_TIMESTAMP
);


-- ==========================================
-- 3. 코멘트(COMMENT) 추가
-- ==========================================

COMMENT ON COLUMN "deliveries"."delivery_status" IS 'PREPARING, SHIPPING, DELIVERED, CANCELLED';
COMMENT ON COLUMN "orders"."order_type" IS 'CART, DIRECT';
COMMENT ON COLUMN "orders"."order_status" IS 'PENDING, PAID, CANCELLED, REFUNDED';
COMMENT ON COLUMN "order_items"."price" IS '주문 당시 가격 스냅샷';
COMMENT ON COLUMN "order_items"."product_name" IS '주문 당시 스냅샷';
COMMENT ON COLUMN "payments"."payment_method" IS '(CREDITCARD, TOSS, KAKAO_PAY, NAVER_PAY)';
COMMENT ON COLUMN "payments"."payment_status" IS 'PENDING, COMPLETE, FAILED, CANCELLED';
COMMENT ON COLUMN "coupon_masters"."coupon_type" IS 'DISCOUNT, SHIPPING';
COMMENT ON COLUMN "coupon_masters"."is_active" IS '쿠폰 발급을 중단시킬 때 필요';
COMMENT ON COLUMN "products"."condition_code" IS 'S_GRADE, A_GRADE, B_GRADE, C_GRADE';
COMMENT ON COLUMN "products"."category_code" IS 'ALL, TOP, BOTTOM, OUTER, ACCESSORY';
COMMENT ON COLUMN "chat_rooms"."sale_id" IS '판매 이벤트 시작 30분 전부터 운영하는 판매자-고객 소통 채팅방';
COMMENT ON COLUMN "users"."name" IS '2~20자';
COMMENT ON COLUMN "users"."nickname" IS '2~12자';
COMMENT ON COLUMN "users"."phone" IS '010-XXXX-XXXX 형식';
COMMENT ON COLUMN "orders"."order_number" IS '날짜+시퀀스 조합 문자열 (예: 20260328-00001)';
COMMENT ON COLUMN "orders"."final_payment_id" IS '결제 성공 시 백엔드에서 UPDATE로 세팅';
COMMENT ON COLUMN "payments"."coupon_id" IS '사용된 쿠폰 (NULL이면 쿠폰 미사용)';


-- ==========================================
-- 4. PK (기본 키) 제약조건 추가
-- ==========================================

ALTER TABLE "users" ADD CONSTRAINT "pk_users" PRIMARY KEY ("user_id");
ALTER TABLE "sale_events" ADD CONSTRAINT "pk_sale_events" PRIMARY KEY ("sale_id");
ALTER TABLE "products" ADD CONSTRAINT "pk_products" PRIMARY KEY ("product_id");
ALTER TABLE "orders" ADD CONSTRAINT "pk_orders" PRIMARY KEY ("orders_id");
ALTER TABLE "deliveries" ADD CONSTRAINT "pk_deliveries" PRIMARY KEY ("delivery_id");
ALTER TABLE "cart_items" ADD CONSTRAINT "pk_cart_items" PRIMARY KEY ("cart_id");
ALTER TABLE "shipping_addresses" ADD CONSTRAINT "pk_shipping_addresses" PRIMARY KEY ("shipping_id");
ALTER TABLE "coupon_masters" ADD CONSTRAINT "pk_coupon_masters" PRIMARY KEY ("coupon_master_id");
ALTER TABLE "coupons" ADD CONSTRAINT "pk_coupons" PRIMARY KEY ("coupon_id");
ALTER TABLE "order_items" ADD CONSTRAINT "pk_order_items" PRIMARY KEY ("order_items_id");
ALTER TABLE "product_images" ADD CONSTRAINT "pk_product_images" PRIMARY KEY ("product_img_id");
ALTER TABLE "payments" ADD CONSTRAINT "pk_payments" PRIMARY KEY ("payment_id");
ALTER TABLE "chat_rooms" ADD CONSTRAINT "pk_chat_rooms" PRIMARY KEY ("chat_room_id");
ALTER TABLE "short_forms" ADD CONSTRAINT "pk_short_forms" PRIMARY KEY ("short_form_id");
ALTER TABLE "style_feeds" ADD CONSTRAINT "pk_style_feeds" PRIMARY KEY ("style_feeds_id");


-- ==========================================
-- 5. UNIQUE 제약조건 추가
-- ==========================================

ALTER TABLE "users" ADD CONSTRAINT "uq_users_email" UNIQUE ("email");
ALTER TABLE "users" ADD CONSTRAINT "uq_users_nickname" UNIQUE ("nickname");
ALTER TABLE "users" ADD CONSTRAINT "uq_users_phone" UNIQUE ("phone");
ALTER TABLE "cart_items" ADD CONSTRAINT "uq_cart_user_product" UNIQUE ("user_id", "product_id");
ALTER TABLE "orders" ADD CONSTRAINT "uq_orders_order_number" UNIQUE ("order_number");
ALTER TABLE "deliveries" ADD CONSTRAINT "uq_deliveries_orders_id" UNIQUE ("orders_id");


-- ==========================================
-- 6. FK (외래 키) 제약조건 추가 (데이터 무결성 보장)
-- ==========================================

ALTER TABLE "products" ADD CONSTRAINT "fk_products_users" FOREIGN KEY ("user_id") REFERENCES "users"("user_id");

ALTER TABLE "orders" ADD CONSTRAINT "fk_orders_users" FOREIGN KEY ("user_id") REFERENCES "users"("user_id");

ALTER TABLE "deliveries" ADD CONSTRAINT "fk_deliveries_orders" FOREIGN KEY ("orders_id") REFERENCES "orders"("orders_id");

ALTER TABLE "cart_items" ADD CONSTRAINT "fk_cart_items_users" FOREIGN KEY ("user_id") REFERENCES "users"("user_id");
ALTER TABLE "cart_items" ADD CONSTRAINT "fk_cart_items_products" FOREIGN KEY ("product_id") REFERENCES "products"("product_id");

ALTER TABLE "shipping_addresses" ADD CONSTRAINT "fk_shipping_users" FOREIGN KEY ("user_id") REFERENCES "users"("user_id");

ALTER TABLE "coupons" ADD CONSTRAINT "fk_coupons_coupon_masters" FOREIGN KEY ("coupon_master_id") REFERENCES "coupon_masters"("coupon_master_id");
ALTER TABLE "coupons" ADD CONSTRAINT "fk_coupons_users" FOREIGN KEY ("user_id") REFERENCES "users"("user_id");

ALTER TABLE "order_items" ADD CONSTRAINT "fk_order_items_products" FOREIGN KEY ("product_id") REFERENCES "products"("product_id");
ALTER TABLE "order_items" ADD CONSTRAINT "fk_order_items_orders" FOREIGN KEY ("orders_id") REFERENCES "orders"("orders_id");

ALTER TABLE "product_images" ADD CONSTRAINT "fk_product_images_products" FOREIGN KEY ("product_id") REFERENCES "products"("product_id");

ALTER TABLE "payments" ADD CONSTRAINT "fk_payments_orders" FOREIGN KEY ("orders_id") REFERENCES "orders"("orders_id");
ALTER TABLE "payments" ADD CONSTRAINT "fk_payments_coupons" FOREIGN KEY ("coupon_id") REFERENCES "coupons"("coupon_id");
ALTER TABLE "orders" ADD CONSTRAINT "fk_orders_final_payment" FOREIGN KEY ("final_payment_id") REFERENCES "payments"("payment_id") DEFERRABLE INITIALLY DEFERRED;

ALTER TABLE "chat_rooms" ADD CONSTRAINT "fk_chat_rooms_users" FOREIGN KEY ("user_id") REFERENCES "users"("user_id");
ALTER TABLE "chat_rooms" ADD CONSTRAINT "fk_chat_rooms_sale_events" FOREIGN KEY ("sale_id") REFERENCES "sale_events"("sale_id");

ALTER TABLE "short_forms" ADD CONSTRAINT "fk_short_forms_products" FOREIGN KEY ("product_id") REFERENCES "products"("product_id");

ALTER TABLE "style_feeds" ADD CONSTRAINT "fk_style_feeds_products" FOREIGN KEY ("product_id") REFERENCES "products"("product_id");


-- ==========================================
-- 7. CHECK 제약조건 추가
-- ==========================================

ALTER TABLE "products" ADD CONSTRAINT "chk_products_price" CHECK ("price" >= 0);
ALTER TABLE "payments" ADD CONSTRAINT "chk_payments_amounts" CHECK (
	"total_product_price" >= 0 AND "delivery_fee" >= 0 AND
	"discount_price" >= 0 AND "total_payment_price" >= 0
);
ALTER TABLE "sale_events" ADD CONSTRAINT "chk_sale_events_dates" CHECK ("sale_end_at" > "sale_start_at");
ALTER TABLE "product_images" ADD CONSTRAINT "chk_product_images_sort_order" CHECK ("sort_order" >= 0);
ALTER TABLE "coupon_masters" ADD CONSTRAINT "chk_coupon_masters_discount" CHECK ("discount_price" >= 0);
ALTER TABLE "order_items" ADD CONSTRAINT "chk_order_items_price" CHECK ("price" >= 0);


-- ==========================================
-- 8. 인덱스 추가
-- ==========================================

CREATE INDEX "idx_products_user_id" ON "products"("user_id");
CREATE INDEX "idx_orders_user_id" ON "orders"("user_id");
CREATE INDEX "idx_orders_final_payment_id" ON "orders"("final_payment_id");
CREATE INDEX "idx_cart_items_product_id" ON "cart_items"("product_id");
CREATE INDEX "idx_shipping_addresses_user_id" ON "shipping_addresses"("user_id");
CREATE INDEX "idx_coupons_user_id" ON "coupons"("user_id");
CREATE INDEX "idx_coupons_coupon_master_id" ON "coupons"("coupon_master_id");
CREATE INDEX "idx_order_items_orders_id" ON "order_items"("orders_id");
CREATE INDEX "idx_order_items_product_id" ON "order_items"("product_id");
CREATE INDEX "idx_product_images_product_id" ON "product_images"("product_id");
CREATE INDEX "idx_payments_orders_id" ON "payments"("orders_id");
CREATE INDEX "idx_payments_coupon_id" ON "payments"("coupon_id");
CREATE INDEX "idx_chat_rooms_user_id" ON "chat_rooms"("user_id");
CREATE INDEX "idx_chat_rooms_sale_id" ON "chat_rooms"("sale_id");
CREATE INDEX "idx_short_forms_product_id" ON "short_forms"("product_id");
CREATE INDEX "idx_style_feeds_product_id" ON "style_feeds"("product_id");
CREATE INDEX "idx_sale_events_period" ON "sale_events"("sale_start_at", "sale_end_at");

-- 부분 UNIQUE 인덱스 (사용자당 기본 배송지 1개, 상품당 대표 이미지 1개)
CREATE UNIQUE INDEX "uq_shipping_one_default_per_user" ON "shipping_addresses"("user_id") WHERE ("is_default" = TRUE);
CREATE UNIQUE INDEX "uq_product_images_one_main" ON "product_images"("product_id") WHERE ("is_main" = TRUE);


-- ==========================================
-- 9. VIEW (is_live를 실시간 계산)
-- ==========================================

CREATE VIEW "live_sale_events" AS
SELECT *,
	(CURRENT_TIMESTAMP BETWEEN "sale_start_at" AND "sale_end_at") AS "is_live"
FROM "sale_events";
